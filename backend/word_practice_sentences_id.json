{
  "deh": {
    "display": "deh",
    "description": "softening particle — gentles requests, shows mild acceptance",
    "usecases": [
      {
        "id": 1,
        "name": "Soften a request",
        "explanation": "Add 'deh' at the end of a request to take the edge off. Without it, the same sentence can sound blunt or demanding. With deh, it becomes casual and friendly — like adding 'will you?' or 'come on' in English. Very common between friends.",
        "demo": {
          "context": "A: Can you drop me off on the way?",
          "native": "Come on, just take me along.",
          "spanish": "Anterin deh."
        },
        "practice": {
          "context": "Adam: I'm heading out — need anything?",
          "english": "Wait a sec for me, will you?",
          "spanish": "Tunggu dulu deh.",
          "accepted_translations": ["Tunggu dulu deh"],
          "hints": [
            { "native": "wait", "learning": "tunggu" },
            { "native": "a sec / first", "learning": "dulu" },
            { "native": "deh", "learning": "deh" }
          ]
        }
      },
      {
        "id": 2,
        "name": "Friendly persuasion",
        "explanation": "Use 'deh' to gently nudge someone into doing something — a soft push, not a command. It signals you're encouraging rather than demanding. Think of it as 'come on, just do it' said with a smile.",
        "demo": {
          "context": "A: I don't really feel like going out.",
          "native": "Just give it a try — come on.",
          "spanish": "Coba dulu deh."
        },
        "practice": {
          "context": "Adam: I'm not sure if I should call her.",
          "english": "Just call her, come on.",
          "spanish": "Telepon aja deh.",
          "accepted_translations": ["Telepon aja deh", "Nelpon aja deh", "Hubungi aja deh"],
          "hints": [
            { "native": "call", "learning": "telepon / hubungi" },
            { "native": "just", "learning": "aja" },
            { "native": "deh", "learning": "deh" }
          ]
        }
      },
      {
        "id": 3,
        "name": "Mild acceptance",
        "explanation": "When you're not thrilled but you're okay with it, 'deh' captures that 'fine, whatever' feeling — mild concession without full enthusiasm. Often paired with 'ya udah' (okay fine) or 'oke'. Very common when going along with someone else's suggestion.",
        "demo": {
          "context": "A: Can we go with this option instead?",
          "native": "Okay, fine then.",
          "spanish": "Ya udah, boleh deh."
        },
        "practice": {
          "context": "Adam: I already bought the tickets — is that okay?",
          "english": "Okay, that's fine then.",
          "spanish": "Ya udah deh.",
          "accepted_translations": ["Ya udah deh", "Oke deh", "Boleh deh"],
          "hints": [
            { "native": "okay / fine", "learning": "ya udah / oke" },
            { "native": "deh", "learning": "deh" }
          ]
        }
      }
    ],
