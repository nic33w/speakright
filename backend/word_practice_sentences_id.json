  "pas": {
    "display": "pas",
    "description": "exactly right / perfect / just right — timing, fit, or precision",
    "usecases": [
      {
        "id": 1,
        "name": "Perfect fit",
        "explanation": "Use 'pas' to say something fits exactly right — clothes, a number, a budget, any match. 'Pas banget' intensifies it: 'fits perfectly'. Also used when an amount is exact — 'uangnya pas' means the money is the exact amount with no change needed.",
        "demo": {
          "context": "A: How does the shirt fit?",
          "native": "It fits perfectly.",
          "spanish": "Pas banget."
        },
        "practice": {
          "context": "Adam: Does that budget cover everything exactly?",
          "english": "It's exactly the right amount.",
          "spanish": "Pas banget jumlahnya.",
          "accepted_translations": ["Pas banget jumlahnya", "Jumlahnya pas banget"],
          "hints": [
            { "native": "exactly right / perfect", "learning": "pas banget" },
            { "native": "the amount", "learning": "jumlahnya" }
          ]
        }
      },
      {
        "id": 2,
        "name": "Perfect timing",
        "explanation": "When something happens at exactly the right moment, use 'pas'. 'Pas kamu datang' = 'just as you arrived' — the timing was spot on. Often describes a lucky coincidence: showing up right when food is ready, or calling someone just before they leave.",
        "demo": {
          "context": "A: When did you get here?",
          "native": "I arrived just as it started.",
          "spanish": "Saya datang pas mulai."
        },
        "practice": {
          "context": "Adam: I was about to leave when you called.",
          "english": "You called at just the right time.",
          "spanish": "Kamu nelpon pas banget.",
          "accepted_translations": ["Kamu nelpon pas banget", "Pas banget kamu nelpon", "Kamu telepon pas banget", "Pas banget kamu telepon"],
          "hints": [
            { "native": "you", "learning": "kamu" },
            { "native": "called (phone)", "learning": "nelpon / telepon" },
            { "native": "just right / perfect timing", "learning": "pas banget" }
          ]
        }
      },
      {
        "id": 3,
        "name": "Exactly / precisely",
        "explanation": "Use 'pas' before a time, number, or description to mean 'exactly' or 'precisely'. 'Pas jam 3' = 'at exactly 3 o'clock'. Often paired with specific numbers, measurements, or details to emphasize accuracy. Very common for times and prices.",
        "demo": {
          "context": "A: When did the movie start?",
          "native": "It started at exactly 8.",
          "spanish": "Mulainya pas jam 8."
        },
        "practice": {
          "context": "Adam: How far is the store from here?",
          "english": "It's exactly 2 kilometers away.",
          "spanish": "Pas 2 kilometer dari sini.",
          "accepted_translations": ["Pas 2 kilometer dari sini", "Jaraknya pas 2 kilometer"],
          "hints": [
            { "native": "exactly", "learning": "pas" },
            { "native": "2 kilometers", "learning": "2 kilometer" },
            { "native": "from here", "learning": "dari sini" }
          ]
        }
      }
    ],
