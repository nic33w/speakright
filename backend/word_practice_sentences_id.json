  "sih": {
    "display": "sih",
    "description": "emphasizing particle — adds curiosity, mild frustration, or soft explanation",
    "usecases": [
      {
        "id": 1,
        "name": "Curious / wondering",
        "explanation": "Add 'sih' to a question to signal genuine curiosity — like a raised eyebrow. It's not accusatory; it's the verbal version of 'how come?' or 'I wonder why…'. Makes questions feel more natural and personal. 'Kenapa sih?' is one of the most common phrases you'll hear.",
        "demo": {
          "context": "A: She didn't show up again.",
          "native": "Why does she keep doing this?",
          "spanish": "Kenapa sih dia gitu terus?"
        },
        "practice": {
          "context": "Adam: I've been waiting for your answer for days.",
          "english": "What's taking so long?",
          "spanish": "Lama banget sih?",
          "accepted_translations": ["Lama banget sih?", "Lama banget sih"],
          "hints": [
            { "native": "takes so long / so slow", "learning": "lama banget" },
            { "native": "sih", "learning": "sih" }
          ]
        }
      },
      {
        "id": 2,
        "name": "Mild frustration",
        "explanation": "When something annoys or surprises you mildly, 'sih' adds that edge of exasperation. It's not a full complaint — more like a 'come on, really?' It won't cause offense between friends, but it does signal you're a bit fed up. Common in phrases like 'Lagi-lagi sih!' (Again with this!)",
        "demo": {
          "context": "A: Oops, I forgot again.",
          "native": "How do you keep forgetting?",
          "spanish": "Kok bisa lupa lagi sih?"
        },
        "practice": {
          "context": "Adam: I dropped my phone again.",
          "english": "Seriously, again?",
          "spanish": "Lagi sih?",
          "accepted_translations": ["Lagi sih?", "Lagi-lagi sih?"],
          "hints": [
            { "native": "again", "learning": "lagi" },
            { "native": "sih", "learning": "sih" }
          ]
        }
      },
      {
        "id": 3,
        "name": "Soft explanation",
        "explanation": "Use 'sih' to soften a statement when you're explaining or clarifying something with a shrug. It signals 'that's just how it is' or 'to be honest…' — low-key rather than blunt. Very natural in 'gitu sih' (that's kind of how it is) or 'sebenernya sih' (honestly / I mean).",
        "demo": {
          "context": "A: Why didn't you say something earlier?",
          "native": "I mean, I didn't know either.",
          "spanish": "Saya juga nggak tau sih."
        },
        "practice": {
          "context": "Adam: So do you actually like the new place?",
          "english": "Honestly, it's not bad.",
          "spanish": "Lumayan sih.",
          "accepted_translations": ["Lumayan sih", "Nggak jelek sih", "Tidak jelek sih"],
          "hints": [
            { "native": "not bad / decent", "learning": "lumayan" },
            { "native": "sih", "learning": "sih" }
          ]
        }
      }
    ],
